# Copia questo file in .env e compila i valori reali
# Mai committare il file .env (contiene password)

# Stringa di connessione PostgreSQL
# Formato: postgresql://UTENTE:PASSWORD@HOST:PORTA/NOME_DATABASE
DATABASE_URL=postgresql://utente:password@localhost:5432/tiformiamonoi

# Segreto per le sessioni (nuxt-auth-utils) — stringa casuale lunga almeno 32 caratteri
NUXT_SESSION_PASSWORD=cambia-questo-con-una-stringa-segreta-lunga-32-caratteri
